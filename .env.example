# =============================================================================
#  Julow Web — Environment Variables
# =============================================================================
#  Скопируйте этот файл в `.env.local` (для локальной разработки) или
#  передайте переменные через docker-compose / Kubernetes / Vercel.
#
#  Все переменные с префиксом `NEXT_PUBLIC_` встраиваются в client bundle
#  на build time и видны браузеру. Без префикса — доступны только в
#  server-side коде (Server Components, Route Handlers, middleware).
# =============================================================================


# ─── Backend API ──────────────────────────────────────────────────────────────
#
# Базовый URL Julow backend (FastAPI). Должен включать `/api/v1` префикс —
# именно по нему серверный код читает endpoint'ы. Без trailing slash.
#
# В docker-compose:    http://backend:8000/api/v1
# Локально (dev):      http://localhost:8000/api/v1
# Production:          https://api.julow.example.com/api/v1
#
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

#
# WebSocket endpoint для real-time чатов, уведомлений, presence.
# Схема: `ws://` для HTTP, `wss://` для HTTPS. Без `/api/v1` префикса.
#
# В docker-compose:    ws://backend:8000
# Локально (dev):      ws://localhost:8000
# Production:          wss://api.julow.example.com
#
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000


# ─── OAuth (опционально, для UI отображения и redirect_uri) ───────────────────
#
# OAuth client_id передаются на backend через провайдер-конфиги
# (см. backend .env: OAUTH_GOOGLE_CLIENT_ID / OAUTH_GITHUB_CLIENT_ID).
# Frontend сам по себе не общается с Google/GitHub API напрямую —
# флоу инициируется через backend endpoint GET /auth/oauth/{provider}/authorize.
#
# Если хотите изменить URL, на который OAuth-провайдер вернёт юзера
# (по умолчанию используется `${origin}/oauth/callback`), переопределите:
#
# NEXT_PUBLIC_OAUTH_REDIRECT_URI=https://app.julow.example.com/oauth/callback


# ─── LiveKit (WebRTC видеовстречи) ─────────────────────────────────────────────
#
# WebSocket URL LiveKit SFU-сервера. Браузер подключается напрямую.
# Схема: `ws://` для dev, `wss://` для production (через nginx/caddy).
#
# В docker-compose:    ws://localhost:7880
# Production:          wss://livekit.julow.example.com
#
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880


# ─── Landing media (опционально) ──────────────────────────────────────────────
#
# Кастомное hero-видео на лендинге. По умолчанию используется MDN demo.
#
# NEXT_PUBLIC_LANDING_HERO_VIDEO=https://cdn.julow.example.com/hero.mp4


# ─── Agentation (только dev) ──────────────────────────────────────────────────
#
# Эндпоинт для визуальных аннотаций агента в dev-режиме. Запуск MCP:
# `npm run dev:agentation-mcp` — стартует на :4747.
#
# NEXT_PUBLIC_AGENTATION_ENDPOINT=http://localhost:4747


# ─── Server-side (без NEXT_PUBLIC_) ───────────────────────────────────────────
#
# Используется только в Server Components / Route Handlers / middleware.
# НЕ попадает в client bundle.
#
# Порт, на котором Next.js standalone сервер слушает в Docker (по умолчанию 3000).
# PORT=3000
# HOSTNAME=0.0.0.0

# Отключение Next.js telemetry — рекомендуется для production.
# NEXT_TELEMETRY_DISABLED=1
